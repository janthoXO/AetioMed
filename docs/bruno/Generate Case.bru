meta {
  name: Generate Case
  type: http
  seq: 3
}

post {
  url: {{base_url}}/api/cases
  body: json
  auth: inherit
}

body:json {
  {
    "diagnosis": "diabetes",
    "generationFlags": [
      "patient",
      "chiefComplaint",
      "anamnesis",
      "procedures"
    ],
    "language": "German",
    "llmConfig": {
      "provider": "ollama",
      "model": "llama3.1"
    }
  }
}

settings {
  encodeUrl: true
  timeout: 0
}
