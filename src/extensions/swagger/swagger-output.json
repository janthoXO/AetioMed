{
  "openapi": "3.0.0",
  "info": {
    "title": "AetioMed API",
    "description": "API Documentation",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "http://localhost:3030/"
    }
  ],
  "tags": [
    {
      "name": "Cases",
      "description": "Cases endpoints"
    }
  ],
  "paths": {},
  "components": {
    "schemas": {
      "CaseGenerationRequest": {
        "type": "object",
        "properties": {
          "icd": {
            "description": "ICD-10 code of the disease to generate a case for",
            "type": "string",
            "format": "icd",
            "pattern": "([A-Z][0-9]{2})(\\.[0-9]{1,4})?"
          },
          "diagnosis": {
            "description": "Name of the disease diagnosis",
            "type": "string"
          },
          "userInstructions": {
            "description": "Additional context for case generation",
            "type": "object",
            "propertyNames": {
              "anyOf": [
                {
                  "type": "string",
                  "enum": [
                    "patient",
                    "chiefComplaint",
                    "anamnesis",
                    "procedures"
                  ]
                },
                {
                  "type": "string",
                  "const": "general"
                }
              ]
            },
            "additionalProperties": {
              "type": "string"
            }
          },
          "generationFlags": {
            "default": ["patient", "chiefComplaint", "anamnesis", "procedures"],
            "description": "Generation flags to specify case fields to generate",
            "type": "array",
            "items": {
              "type": "string",
              "enum": ["patient", "chiefComplaint", "anamnesis", "procedures"]
            }
          },
          "language": {
            "description": "Language to generate the case in",
            "type": "string",
            "enum": ["English", "German"]
          },
          "anamnesisCategories": {
            "description": "Categories of anamnesis to include in the case",
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "llmConfig": {
            "description": "Optional configuration for the LLM used in case generation",
            "type": "object",
            "properties": {
              "provider": {
                "type": "string",
                "enum": ["ollama", "google"]
              },
              "model": {
                "type": "string"
              },
              "apiKey": {
                "type": "string"
              },
              "url": {
                "type": "string",
                "format": "uri"
              },
              "temperature": {
                "default": 0.7,
                "type": "number",
                "minimum": 0,
                "maximum": 1
              },
              "outputFormat": {
                "default": "json",
                "type": "string",
                "enum": ["json", "text"]
              }
            },
            "required": ["temperature", "outputFormat"],
            "additionalProperties": false
          },
          "traceId": {
            "description": "Optional unique ID to track generation progress via SSE",
            "type": "string"
          }
        },
        "required": ["generationFlags"],
        "additionalProperties": false
      },
      "CaseGenerationResponse": {
        "anyOf": [
          {
            "type": "object",
            "properties": {
              "patient": {
                "type": "object",
                "properties": {
                  "name": {
                    "type": "string"
                  },
                  "age": {
                    "type": "integer",
                    "minimum": 0,
                    "maximum": 9007199254740991
                  },
                  "height": {
                    "type": "number",
                    "minimum": 0
                  },
                  "weight": {
                    "type": "number",
                    "minimum": 0
                  },
                  "gender": {
                    "type": "string",
                    "enum": ["male", "female"]
                  },
                  "race": {
                    "type": "string"
                  }
                },
                "required": ["name", "age", "height", "weight", "gender"],
                "additionalProperties": false
              },
              "chiefComplaint": {
                "type": "string",
                "description": "The chief complaint of the patient"
              },
              "anamnesis": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "category": {
                      "type": "string",
                      "description": "Category of the anamnesis field"
                    },
                    "answer": {
                      "type": "string",
                      "description": "Patient's response or clinical finding"
                    }
                  },
                  "required": ["category", "answer"],
                  "additionalProperties": false
                },
                "description": "Medical history collected from patient"
              },
              "procedures": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "name": {
                      "type": "string",
                      "description": "Name of the medical procedure"
                    },
                    "relevance": {
                      "type": "string",
                      "enum": ["obligatory", "optional", "contraindicated"],
                      "description": "Relevance of the procedure to the diagnosis"
                    },
                    "result": {
                      "type": "string",
                      "description": "Result of the procedure, if applicable"
                    }
                  },
                  "required": ["name", "relevance", "result"],
                  "additionalProperties": false
                }
              },
              "traceId": {
                "type": "string"
              }
            },
            "additionalProperties": false
          },
          {
            "type": "object",
            "properties": {
              "error": {
                "type": "object",
                "properties": {
                  "code": {
                    "type": "string"
                  },
                  "message": {
                    "type": "string"
                  },
                  "details": {
                    "type": "string"
                  }
                },
                "required": ["code", "message"],
                "additionalProperties": false
              }
            },
            "required": ["error"],
            "additionalProperties": false
          }
        ]
      }
    }
  }
}
